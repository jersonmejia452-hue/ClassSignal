# URL pública del proyecto (Project Settings > API Keys en Supabase).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Clave publicable para el navegador (formato sb_publishable_...).
# Nunca uses aquí una secret key ni la clave service_role.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Origen público usado al crear enlaces y códigos QR.
# Es opcional; si se omite, la aplicación usa window.location.origin.
VITE_PUBLIC_APP_URL=http://localhost:5173

# Supabase Auth debe permitir usuarios nuevos para el Magic Link estudiantil.
# El cliente no registra profesores: ese rol se concede solo por administración.

# Solo servidor: la Edge Function lee esta variable; Vite no la publica.
# Configúrala como secreto de Supabase y nunca le añadas el prefijo VITE_.
OPENAI_API_KEY=sk-your-openai-api-key

# Solo servidor: secreto aleatorio dedicado a seudonimizar respuestas y redes.
# Usa 32 bytes aleatorios codificados en base64url (43+ caracteres).
RESPONSE_HMAC_SECRET=replace-with-32-random-bytes

# Solo servidor: claves del widget invisible de Cloudflare Turnstile.
# La site key se entrega al cliente desde la Edge Function; la secret key nunca.
TURNSTILE_SITE_KEY=replace-with-your-turnstile-site-key
TURNSTILE_SECRET_KEY=replace-with-your-turnstile-secret-key

# Obligatorio: hostnames exactos, separados por comas y sin protocolo ni ruta.
# En desarrollo local usa: localhost,127.0.0.1
TURNSTILE_EXPECTED_HOSTNAMES=localhost,127.0.0.1
